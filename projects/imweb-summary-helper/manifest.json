{
  "manifest_version": 3,
  "name": "아임웹 상품 요약설명 도우미",
  "version": "1.0.0",
  "description": "아임웹 관리자 상품 편집 화면에서 상품명·카테고리를 반영한 요약 설명 초안을 톤별로 생성하고 에디터에 바로 적용합니다.",
  "author": "DEDO",
  "minimum_chrome_version": "111",
  "content_scripts": [
    {
      "matches": ["https://*/admin/shopping/product/detail*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
