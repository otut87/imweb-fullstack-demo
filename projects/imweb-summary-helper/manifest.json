{
  "manifest_version": 3,
  "name": "아임웹 상품 요약설명 도우미",
  "version": "2.0.0",
  "description": "아임웹 관리자 상품 수정 화면에서 아이콘을 누르면 상품명·카테고리를 반영한 요약 설명 초안을 만들어 에디터에 바로 적용합니다.",
  "author": "DEDO",
  "minimum_chrome_version": "111",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "요약설명 도우미",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
