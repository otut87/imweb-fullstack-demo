# ── 아임웹 OAuth 앱 (개발자센터 developers.imweb.me에서 앱 등록 후 발급) ──
IMWEB_CLIENT_ID=
IMWEB_CLIENT_SECRET=
# 연동할 사이트 코드 (support51251 샘플사이트)
IMWEB_SITE_CODE=
# /site-info의 unitList[].unitCode — 주문·상품·회원 조회에 필수
IMWEB_UNIT_CODE=
# 개발자센터 앱에 등록한 redirect URI와 정확히 일치해야 함
IMWEB_REDIRECT_URI=http://localhost:8000/auth/callback
# 공백 구분 scope (실검증 확정) — 개발자센터 앱에서 동일하게 활성화할 것
IMWEB_SCOPE=site-info:write order:read order:write product:read payment:write member-info:read

# ── 웹훅 ──
# 웹훅 URL에 ?secret=... 로 붙여 등록할 임의의 긴 문자열
WEBHOOK_SHARED_SECRET=change-me
# 개발자센터 웹훅 화면의 '인증정보' 값 (이벤트의 authorization 헤더로 전달됨)
IMWEB_WEBHOOK_AUTH=

# ── 폴링/푸시 (앱 심사 승인 전 웹훅 폴백 + ERP→아임웹 역방향 동기화) ──
IMWEB_POLL_ENABLED=1
IMWEB_POLL_INTERVAL=30
IMWEB_PUSH_ENABLED=1

# ── 카카오 '나에게 보내기' 주문 알림 (선택 — 미설정 시 알림만 생략) ──
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# ── 크롬 확장 '요약설명 도우미' AI 프록시 (선택 — 비우면 /api/summary가 503) ──
ANTHROPIC_API_KEY=

# ── 배포(prod compose) / DB ──
# docker-compose.prod.yml이 Caddy 자동 TLS에 사용 (예: 15.165.133.165.sslip.io)
DOMAIN=
DB_PATH=enchante_erp.db
