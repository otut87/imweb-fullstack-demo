# 아임웹 개발자센터(developers.imweb.me)에서 앱 등록 후 발급
IMWEB_CLIENT_ID=
IMWEB_CLIENT_SECRET=
# 연동할 사이트 코드 (support51251 샘플사이트)
IMWEB_SITE_CODE=
# 개발자센터 앱에 등록한 redirect URI와 정확히 일치해야 함
IMWEB_REDIRECT_URI=http://localhost:8000/auth/callback
# 공백 구분 scope 목록 — 개발자센터 앱 설정에서 활성화한 scope와 맞출 것 (TODO: 정확한 scope 명칭 확인)
IMWEB_SCOPE=order:read product:read member:read

# 웹훅 수신 검증용 임의 시크릿 (웹훅 URL에 ?secret=... 로 붙여 등록)
WEBHOOK_SHARED_SECRET=change-me

# SQLite 파일 경로
DB_PATH=enchante_erp.db
